// ===================================================
// Orynthia - Prisma Schema
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Benutzer ----------
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")

  // 2FA
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?  @map("two_factor_secret")

  // Refresh Token
  refreshToken   String?   @map("refresh_token")

  // Einstellungen
  preferredCurrency String  @default("EUR") @map("preferred_currency")
  theme            String   @default("dark") // dark | light
  locale           String   @default("de")

  // Status
  isActive       Boolean   @default(true) @map("is_active")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")

  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLoginAt    DateTime? @map("last_login_at")

  // Relations
  bankAccounts   BankAccount[]
  categories     Category[]
  budgets        Budget[]
  recurringPayments RecurringPayment[]
  savingsGoals   SavingsGoal[]
  notifications  Notification[]
  bankConnections BankConnection[]
  contracts      Contract[]
  categorizationRules CategorizationRule[]
  assets         Asset[]
  households     HouseholdMember[]
  sharedExpenses SharedExpense[]
  sharedExpenseShares SharedExpenseShare[]
  portfolioHoldings PortfolioHolding[]

  @@map("users")
}

// ---------- Bankkonten ----------
model BankAccount {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")

  bankName        String    @map("bank_name")
  accountName     String    @map("account_name")
  iban            String?
  bic             String?
  accountType     AccountType @default(CHECKING) @map("account_type")

  // Kontostand
  balance         Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("EUR")

  // Banking API Verbindung (verschlüsselt)
  externalId      String?   @map("external_id")
  accessToken     String?   @map("access_token")
  refreshToken    String?   @map("refresh_token")
  consentExpiry   DateTime? @map("consent_expiry")

  // Status
  isActive        Boolean   @default(true) @map("is_active")
  lastSynced      DateTime? @map("last_synced")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("bank_accounts")
}

enum AccountType {
  CHECKING
  SAVINGS
  CREDIT_CARD
  DEPOT
  LOAN
  OTHER
}

// ---------- Transaktionen ----------
model Transaction {
  id              String    @id @default(uuid())
  bankAccountId   String    @map("bank_account_id")
  categoryId      String?   @map("category_id")

  // Transaktionsdaten
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("EUR")
  originalAmount  Decimal?  @map("original_amount") @db.Decimal(12, 2)
  originalCurrency String?  @map("original_currency")
  exchangeRate    Decimal?  @map("exchange_rate") @db.Decimal(12, 6)
  date            DateTime
  valueDate       DateTime? @map("value_date")

  // Details
  purpose         String?
  counterpartName String?   @map("counterpart_name")
  counterpartIban String?   @map("counterpart_iban")

  // Typ & Status
  type            TransactionType @default(OTHER)
  isRecurring     Boolean   @default(false) @map("is_recurring")
  recurringPaymentId String? @map("recurring_payment_id")

  // Externe Referenz
  externalId      String?   @map("external_id") @unique

  // Notizen & Tags
  notes           String?
  tags            String[]  @default([])

  // Splittbuchungen
  splitTransactions TransactionSplit[]

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category        Category?   @relation(fields: [categoryId], references: [id])
  recurringPayment RecurringPayment? @relation(fields: [recurringPaymentId], references: [id])

  @@index([bankAccountId, date])
  @@index([categoryId])
  @@index([date])
  @@index([tags])
  @@map("transactions")
}

// ---------- Splittbuchungen ----------
model TransactionSplit {
  id            String   @id @default(uuid())
  transactionId String   @map("transaction_id")
  categoryId    String?  @map("category_id")
  amount        Decimal  @db.Decimal(12, 2)
  note          String?

  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  category      Category?   @relation(fields: [categoryId], references: [id])

  @@map("transaction_splits")
}

enum TransactionType {
  INCOME
  EXPENSE
  TRANSFER
  STANDING_ORDER
  DIRECT_DEBIT
  OTHER
}

// ---------- Kategorien ----------
model Category {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id")

  name        String
  icon        String?
  color       String?
  parentId    String?   @map("parent_id")
  isSystem    Boolean   @default(false) @map("is_system")

  // Keywords für Auto-Kategorisierung
  keywords    String[]  @default([])

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]
  recurringPayments RecurringPayment[]
  transactionSplits TransactionSplit[]
  categorizationRules CategorizationRule[]

  @@unique([userId, name])
  @@map("categories")
}

// ---------- Kategorisierungsregeln ----------
model CategorizationRule {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  categoryId  String    @map("category_id")

  // Regel-Bedingungen
  field       RuleField // Welches Feld wird geprüft
  operator    RuleOperator // Vergleichsoperator
  value       String    // Wert zum Vergleichen

  // Priorität (höher = wird zuerst angewendet)
  priority    Int       @default(0)
  isActive    Boolean   @default(true) @map("is_active")

  // Lernend: wie oft wurde diese Regel angewendet
  appliedCount Int      @default(0) @map("applied_count")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id])

  @@index([userId, isActive])
  @@map("categorization_rules")
}

enum RuleField {
  COUNTERPART_NAME
  COUNTERPART_IBAN
  PURPOSE
  AMOUNT_MIN
  AMOUNT_MAX
}

enum RuleOperator {
  EQUALS
  CONTAINS
  STARTS_WITH
  ENDS_WITH
  REGEX
  GREATER_THAN
  LESS_THAN
}

// ---------- Budgets ----------
model Budget {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  categoryId  String    @map("category_id")

  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  period      BudgetPeriod @default(MONTHLY)

  // Warnungen
  warningThreshold Int  @default(80) @map("warning_threshold") // Prozent

  // Zeitraum
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")

  // Status
  isActive    Boolean   @default(true) @map("is_active")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period])
  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ---------- Wiederkehrende Zahlungen ----------
model RecurringPayment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  categoryId  String?   @map("category_id")

  name        String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  frequency   PaymentFrequency @default(MONTHLY)

  counterpartName String? @map("counterpart_name")
  nextDueDate DateTime?  @map("next_due_date")
  lastChargeDate DateTime? @map("last_charge_date")

  isActive    Boolean   @default(true) @map("is_active")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category? @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("recurring_payments")
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  BIANNUALLY
  YEARLY
}

// ---------- Sparziele ----------
model SavingsGoal {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  name        String
  targetAmount Decimal  @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal @default(0) @map("current_amount") @db.Decimal(12, 2)
  currency    String    @default("EUR")

  deadline    DateTime?
  icon        String?
  color       String?

  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

// ---------- Verträge ----------
model Contract {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")

  name            String
  provider        String
  contractType    ContractType @map("contract_type")

  monthlyCost     Decimal?  @map("monthly_cost") @db.Decimal(12, 2)
  yearlyCost      Decimal?  @map("yearly_cost") @db.Decimal(12, 2)
  billingCycle    BillingCycle @default(MONTHLY) @map("billing_cycle")

  contractNumber  String?   @map("contract_number")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  cancellationDate DateTime? @map("cancellation_date")
  noticePeriod    String?   @map("notice_period")
  autoRenewal     Boolean   @default(true) @map("auto_renewal")

  details         Json?

  counterpartName String?   @map("counterpart_name")
  counterpartIban String?   @map("counterpart_iban")

  avgMonthlyAmount Decimal? @map("avg_monthly_amount") @db.Decimal(12, 2)
  transactionCount Int      @default(0) @map("transaction_count")
  lastChargeDate  DateTime? @map("last_charge_date")

  isActive        Boolean   @default(true) @map("is_active")
  isAutoDetected  Boolean   @default(false) @map("is_auto_detected")

  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("contracts")
}

enum ContractType {
  INSURANCE_LIABILITY
  INSURANCE_HOUSEHOLD
  INSURANCE_HEALTH
  INSURANCE_DENTAL
  INSURANCE_LIFE
  INSURANCE_CAR
  INSURANCE_LEGAL
  INSURANCE_DISABILITY
  INSURANCE_OTHER
  ENERGY_ELECTRICITY
  ENERGY_GAS
  TELECOM_MOBILE
  TELECOM_INTERNET
  TELECOM_LANDLINE
  STREAMING
  GYM
  SUBSCRIPTION
  RENT
  LEASE
  LOAN
  OTHER
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  BIANNUALLY
  YEARLY
}

// ---------- Benachrichtigungen ----------
model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  type        NotificationType
  title       String
  message     String
  data        Json?

  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")

  createdAt   DateTime  @default(now()) @map("created_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  BUDGET_WARNING
  BUDGET_EXCEEDED
  LARGE_TRANSACTION
  LOW_BALANCE
  CONTRACT_REMINDER
  RECURRING_DETECTED
  SAVINGS_MILESTONE
  UNUSUAL_SPENDING
  SYNC_ERROR
  SYSTEM
}

// ---------- Vermögenswerte ----------
model Asset {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  name        String
  assetType   AssetType @map("asset_type")
  value       Decimal   @db.Decimal(14, 2)
  currency    String    @default("EUR")

  // Für Schulden/Kredite
  isLiability Boolean   @default(false) @map("is_liability")
  interestRate Decimal? @map("interest_rate") @db.Decimal(5, 2)

  // Details
  institution String?
  notes       String?

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots   AssetSnapshot[]

  @@index([userId])
  @@map("assets")
}

enum AssetType {
  REAL_ESTATE
  VEHICLE
  INVESTMENT
  CRYPTO
  CASH
  OTHER_ASSET
  MORTGAGE
  CONSUMER_LOAN
  STUDENT_LOAN
  OTHER_LIABILITY
}

// ---------- Vermögens-Snapshots (für Zeitverlauf) ----------
model AssetSnapshot {
  id        String   @id @default(uuid())
  assetId   String   @map("asset_id")
  value     Decimal  @db.Decimal(14, 2)
  date      DateTime @default(now())

  asset     Asset    @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId, date])
  @@map("asset_snapshots")
}

// ---------- Haushalte (Shared Expenses) ----------
model Household {
  id          String    @id @default(uuid())
  name        String

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  members     HouseholdMember[]
  expenses    SharedExpense[]

  @@map("households")
}

model HouseholdMember {
  id          String    @id @default(uuid())
  householdId String    @map("household_id")
  userId      String?   @map("user_id")
  name        String    // Für nicht-registrierte Mitglieder
  role        HouseholdRole @default(MEMBER)

  createdAt   DateTime  @default(now()) @map("created_at")

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id])
  shares      SharedExpenseShare[]

  @@unique([householdId, userId])
  @@map("household_members")
}

enum HouseholdRole {
  ADMIN
  MEMBER
}

model SharedExpense {
  id          String    @id @default(uuid())
  householdId String    @map("household_id")
  paidById    String    @map("paid_by_id") // User who paid

  description String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  date        DateTime  @default(now())

  splitType   SplitType @default(EQUAL) @map("split_type")

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  household   Household @relation(fields: [householdId], references: [id], onDelete: Cascade)
  paidBy      User      @relation(fields: [paidById], references: [id])
  shares      SharedExpenseShare[]

  @@index([householdId])
  @@map("shared_expenses")
}

model SharedExpenseShare {
  id          String    @id @default(uuid())
  expenseId   String    @map("expense_id")
  memberId    String    @map("member_id")
  userId      String?   @map("user_id")
  amount      Decimal   @db.Decimal(12, 2)
  isSettled   Boolean   @default(false) @map("is_settled")

  expense     SharedExpense    @relation(fields: [expenseId], references: [id], onDelete: Cascade)
  member      HouseholdMember  @relation(fields: [memberId], references: [id])
  user        User?            @relation(fields: [userId], references: [id])

  @@map("shared_expense_shares")
}

enum SplitType {
  EQUAL
  PERCENTAGE
  CUSTOM
}

// ---------- Portfolio/Depot ----------
model PortfolioHolding {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")

  symbol      String    // z.B. "BTC", "ETH", "AAPL"
  name        String    // z.B. "Bitcoin", "Apple Inc."
  holdingType HoldingType @map("holding_type")

  quantity    Decimal   @db.Decimal(18, 8)
  avgBuyPrice Decimal   @map("avg_buy_price") @db.Decimal(14, 2)
  currentPrice Decimal  @map("current_price") @db.Decimal(14, 2)
  currency    String    @default("EUR")

  // Externes Tracking
  exchange    String?   // z.B. "XETRA", "BINANCE"
  isin        String?   // Für Aktien/ETFs

  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("portfolio_holdings")
}

enum HoldingType {
  STOCK
  ETF
  BOND
  CRYPTO
  FUND
  OTHER
}

// ---------- Bank-Verbindungen ----------
model BankConnection {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")

  provider              String
  externalConnectionId  String    @map("external_connection_id")
  institutionId         String    @map("institution_id")
  institutionName       String?   @map("institution_name")
  institutionLogo       String?   @map("institution_logo")
  sessionId             String?   @map("session_id")

  status                String    @default("CREATED")

  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  expiresAt             DateTime? @map("expires_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_connections")
}
