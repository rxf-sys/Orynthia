// ===================================================
// Orynthia - Prisma Schema
// ===================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------- Benutzer ----------
model User {
  id             String    @id @default(uuid())
  email          String    @unique
  passwordHash   String    @map("password_hash")
  firstName      String?   @map("first_name")
  lastName       String?   @map("last_name")
  
  // 2FA
  twoFactorEnabled Boolean  @default(false) @map("two_factor_enabled")
  twoFactorSecret  String?  @map("two_factor_secret")
  
  // Refresh Token
  refreshToken   String?   @map("refresh_token")
  
  // Status
  isActive       Boolean   @default(true) @map("is_active")
  isEmailVerified Boolean  @default(false) @map("is_email_verified")
  
  // Timestamps
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")
  lastLoginAt    DateTime? @map("last_login_at")
  
  // Relations
  bankAccounts   BankAccount[]
  categories     Category[]
  budgets        Budget[]
  recurringPayments RecurringPayment[]
  savingsGoals   SavingsGoal[]
  notifications  Notification[]
  bankConnections BankConnection[]
  contracts      Contract[]

  @@map("users")
}

// ---------- Bankkonten ----------
model BankAccount {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  
  bankName        String    @map("bank_name")
  accountName     String    @map("account_name")
  iban            String?
  bic             String?
  accountType     AccountType @default(CHECKING) @map("account_type")
  
  // Kontostand
  balance         Decimal   @default(0) @db.Decimal(12, 2)
  currency        String    @default("EUR")
  
  // Banking API Verbindung (verschlüsselt)
  externalId      String?   @map("external_id")
  accessToken     String?   @map("access_token") // AES-256 verschlüsselt
  refreshToken    String?   @map("refresh_token") // AES-256 verschlüsselt
  consentExpiry   DateTime? @map("consent_expiry")
  
  // Status
  isActive        Boolean   @default(true) @map("is_active")
  lastSynced      DateTime? @map("last_synced")
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("bank_accounts")
}

enum AccountType {
  CHECKING    // Girokonto
  SAVINGS     // Sparkonto
  CREDIT_CARD // Kreditkarte
  DEPOT       // Wertpapierdepot
  LOAN        // Kredit
  OTHER       // Sonstige
}

// ---------- Transaktionen ----------
model Transaction {
  id              String    @id @default(uuid())
  bankAccountId   String    @map("bank_account_id")
  categoryId      String?   @map("category_id")
  
  // Transaktionsdaten
  amount          Decimal   @db.Decimal(12, 2)
  currency        String    @default("EUR")
  date            DateTime
  valueDate       DateTime? @map("value_date")
  
  // Details
  purpose         String?   // Verwendungszweck
  counterpartName String?   @map("counterpart_name")
  counterpartIban String?   @map("counterpart_iban")
  
  // Typ & Status
  type            TransactionType @default(OTHER)
  isRecurring     Boolean   @default(false) @map("is_recurring")
  recurringPaymentId String? @map("recurring_payment_id")
  
  // Externe Referenz
  externalId      String?   @map("external_id") @unique
  
  // Notizen
  notes           String?
  tags            String[]  @default([])
  
  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  
  // Relations
  bankAccount     BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  category        Category?   @relation(fields: [categoryId], references: [id])
  recurringPayment RecurringPayment? @relation(fields: [recurringPaymentId], references: [id])

  @@index([bankAccountId, date])
  @@index([categoryId])
  @@index([date])
  @@map("transactions")
}

enum TransactionType {
  INCOME          // Einnahme
  EXPENSE         // Ausgabe
  TRANSFER        // Umbuchung
  STANDING_ORDER  // Dauerauftrag
  DIRECT_DEBIT    // Lastschrift
  OTHER           // Sonstige
}

// ---------- Kategorien ----------
model Category {
  id          String    @id @default(uuid())
  userId      String?   @map("user_id") // null = System-Kategorie
  
  name        String
  icon        String?
  color       String?   // Hex-Farbcode
  parentId    String?   @map("parent_id")
  isSystem    Boolean   @default(false) @map("is_system")
  
  // Keywords für Auto-Kategorisierung
  keywords    String[]  @default([])
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user         User?        @relation(fields: [userId], references: [id], onDelete: Cascade)
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  transactions Transaction[]
  budgets      Budget[]
  recurringPayments RecurringPayment[]

  @@unique([userId, name])
  @@map("categories")
}

// ---------- Budgets ----------
model Budget {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  categoryId  String    @map("category_id")
  
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  period      BudgetPeriod @default(MONTHLY)
  
  // Zeitraum
  startDate   DateTime  @map("start_date")
  endDate     DateTime? @map("end_date")
  
  // Status
  isActive    Boolean   @default(true) @map("is_active")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category  @relation(fields: [categoryId], references: [id])

  @@unique([userId, categoryId, period])
  @@map("budgets")
}

enum BudgetPeriod {
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
}

// ---------- Wiederkehrende Zahlungen (Abos) ----------
model RecurringPayment {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  categoryId  String?   @map("category_id")

  name        String
  amount      Decimal   @db.Decimal(12, 2)
  currency    String    @default("EUR")
  frequency   PaymentFrequency @default(MONTHLY)

  // Details
  counterpartName String? @map("counterpart_name")
  nextDueDate DateTime?  @map("next_due_date")
  lastChargeDate DateTime? @map("last_charge_date")

  // Status
  isActive    Boolean   @default(true) @map("is_active")

  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  // Relations
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category? @relation(fields: [categoryId], references: [id])
  transactions Transaction[]

  @@index([userId])
  @@map("recurring_payments")
}

enum PaymentFrequency {
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  BIANNUALLY
  YEARLY
}

// ---------- Sparziele ----------
model SavingsGoal {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  
  name        String
  targetAmount Decimal  @map("target_amount") @db.Decimal(12, 2)
  currentAmount Decimal @default(0) @map("current_amount") @db.Decimal(12, 2)
  currency    String    @default("EUR")
  
  // Deadline
  deadline    DateTime?
  icon        String?
  color       String?
  
  // Status
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("savings_goals")
}

// ---------- Verträge ----------
model Contract {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")

  // Vertragsdaten
  name            String    // z.B. "Haftpflichtversicherung", "Strom Vattenfall"
  provider        String    // z.B. "Allianz", "Vattenfall", "Telekom"
  contractType    ContractType @map("contract_type")

  // Kosten
  monthlyCost     Decimal?  @map("monthly_cost") @db.Decimal(12, 2)
  yearlyCost      Decimal?  @map("yearly_cost") @db.Decimal(12, 2)
  billingCycle    BillingCycle @default(MONTHLY) @map("billing_cycle")

  // Vertragsdetails
  contractNumber  String?   @map("contract_number")
  startDate       DateTime? @map("start_date")
  endDate         DateTime? @map("end_date")
  cancellationDate DateTime? @map("cancellation_date") // Kündigungsfrist
  noticePeriod    String?   @map("notice_period") // z.B. "3 Monate"
  autoRenewal     Boolean   @default(true) @map("auto_renewal")

  // Provider-spezifisch (Versicherung, Strom etc.)
  details         Json?     // Flexible Zusatzinfos (kWh-Preis, Deckungssumme, Tarif etc.)

  // Erkennungsmuster
  counterpartName String?   @map("counterpart_name") // Für Auto-Erkennung
  counterpartIban String?   @map("counterpart_iban")

  // Durchschnitt aus Transaktionen
  avgMonthlyAmount Decimal? @map("avg_monthly_amount") @db.Decimal(12, 2)
  transactionCount Int      @default(0) @map("transaction_count")
  lastChargeDate  DateTime? @map("last_charge_date")

  // Status
  isActive        Boolean   @default(true) @map("is_active")
  isAutoDetected  Boolean   @default(false) @map("is_auto_detected")

  // Timestamps
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  // Relations
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("contracts")
}

enum ContractType {
  INSURANCE_LIABILITY     // Haftpflicht
  INSURANCE_HOUSEHOLD     // Hausrat
  INSURANCE_HEALTH        // Krankenversicherung
  INSURANCE_DENTAL        // Zahnzusatzversicherung
  INSURANCE_LIFE          // Lebensversicherung
  INSURANCE_CAR           // KFZ-Versicherung
  INSURANCE_LEGAL         // Rechtsschutz
  INSURANCE_DISABILITY    // Berufsunfähigkeit
  INSURANCE_OTHER         // Sonstige Versicherung
  ENERGY_ELECTRICITY      // Strom
  ENERGY_GAS              // Gas
  TELECOM_MOBILE          // Mobilfunk
  TELECOM_INTERNET        // Internet/DSL
  TELECOM_LANDLINE        // Festnetz
  STREAMING               // Netflix, Spotify etc.
  GYM                     // Fitnessstudio
  SUBSCRIPTION            // Sonstige Abos
  RENT                    // Miete
  LEASE                   // Leasing
  LOAN                    // Kredit/Darlehen
  OTHER                   // Sonstige
}

enum BillingCycle {
  MONTHLY
  QUARTERLY
  BIANNUALLY
  YEARLY
}

// ---------- Benachrichtigungen ----------
model Notification {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  
  type        NotificationType
  title       String
  message     String
  data        Json?     // Zusätzliche Daten
  
  isRead      Boolean   @default(false) @map("is_read")
  readAt      DateTime? @map("read_at")
  
  // Timestamps
  createdAt   DateTime  @default(now()) @map("created_at")
  
  // Relations
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@map("notifications")
}

enum NotificationType {
  BUDGET_WARNING     // Budget fast aufgebraucht
  BUDGET_EXCEEDED    // Budget überschritten
  LARGE_TRANSACTION  // Große Transaktion erkannt
  RECURRING_DETECTED // Neues Abo erkannt
  SAVINGS_MILESTONE  // Sparziel Meilenstein
  SYNC_ERROR         // Bank-Sync Fehler
  SYSTEM             // System-Nachricht
}

// ---------- Bank-Verbindungen (Open Banking) ----------
model BankConnection {
  id                    String    @id @default(uuid())
  userId                String    @map("user_id")

  provider              String    // "enablebanking" | "finapi"
  externalConnectionId  String    @map("external_connection_id")
  institutionId         String    @map("institution_id")
  institutionName       String?   @map("institution_name")
  institutionLogo       String?   @map("institution_logo")
  sessionId             String?   @map("session_id") // Enable Banking Session ID

  status                String    @default("CREATED") // CREATED, LINKED, EXPIRED, etc.

  // Timestamps
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  expiresAt             DateTime? @map("expires_at")

  // Relations
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bank_connections")
}
