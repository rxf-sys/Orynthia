# ===========================================
# Finanzguru App - Environment Configuration
# ===========================================
# Kopiere diese Datei zu .env und passe die Werte an

# ---------- Allgemein ----------
NODE_ENV=development
APP_PORT=3000
FRONTEND_URL=http://localhost:5173

# ---------- Datenbank ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=finanzguru
POSTGRES_PASSWORD=CHANGE_ME_secure_password_123
POSTGRES_DB=finanzguru
DATABASE_URL=postgresql://finanzguru:CHANGE_ME_secure_password_123@postgres:5432/finanzguru?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_456

# ---------- JWT / Auth ----------
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Verschlüsselung ----------
ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!

# ---------- Banking API (finAPI) ----------
FINAPI_CLIENT_ID=your_finapi_client_id
FINAPI_CLIENT_SECRET=your_finapi_client_secret
FINAPI_BASE_URL=https://sandbox.finapi.io

# ---------- Optionale KI-Integration ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- E-Mail (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@finanzguru.local

# ---------- Sentry (optional) ----------
SENTRY_DSN=
