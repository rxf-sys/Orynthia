# ===========================================
# Orynthia App - Environment Configuration
# ===========================================
# Kopiere diese Datei zu .env und passe die Werte an

# ---------- Allgemein ----------
NODE_ENV=production
APP_PORT=3000
FRONTEND_URL=http://localhost:5173

# Cookies über HTTPS erzwingen (true für HTTPS-Deployments, false für HTTP/Homeserver)
COOKIE_SECURE=false

# Swagger UI aktivieren (true nur für Entwicklung/Debugging)
SWAGGER_ENABLED=false

# Demo-User mit Test-Daten beim Container-Start anlegen.
# Wenn true: bei jedem Start wird demo@orynthia.local mit allen Daten
# (Konten, Transaktionen, Budgets, Sparziele, Verträge, …) frisch
# erzeugt; vorhandene Demo-Daten werden vorher gelöscht.
# WARNUNG: Nicht in echter Produktion aktivieren – der Demo-User ist
# öffentlich bekannt (Default-Passwort "demo1234", überschreibbar via DEMO_PASSWORD).
SEED_DEMO_USER=false
# DEMO_PASSWORD=eigenes_demo_passwort

# ---------- Datenbank ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orynthia
POSTGRES_PASSWORD=CHANGE_ME_secure_password_123
POSTGRES_DB=orynthia
DATABASE_URL=postgresql://orynthia:CHANGE_ME_secure_password_123@postgres:5432/orynthia?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_456
# Optional: wenn gesetzt, prüft /api/ready zusätzlich die Redis-Erreichbarkeit
# REDIS_URL=redis://:CHANGE_ME_redis_password_456@redis:6379

# ---------- JWT / Auth ----------
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Verschlüsselung (AES-256-GCM) ----------
# Verschlüsselt sensible Daten (2FA-Secret, Banking-Session-ID) at rest.
# Bevorzugt: 64 Hex-Zeichen = 32 Byte = AES-256.
# Generieren: `openssl rand -hex 32` oder `node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"`
# Hinweis: Wenn der Key später rotiert wird, sind bestehende verschlüsselte Werte nicht mehr lesbar (2FA muss neu eingerichtet, Banking neu verbunden werden).
ENCRYPTION_KEY=CHANGE_ME_64_hex_chars_run_openssl_rand_hex_32_to_generate

# ---------- Banking API (Enable Banking / Open Banking PSD2) ----------
# Kostenlos registrieren: https://enablebanking.com/sign-in/
# App erstellen unter: https://enablebanking.com (Control Panel -> API Applications)
# Private Key wird beim App-Erstellen generiert (RSA, PEM-Format)
# Im .env den Key einzeilig mit \n als Zeilenumbruch speichern
ENABLE_BANKING_APP_ID=your_application_id
ENABLE_BANKING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----"

# ---------- Optionale KI-Integration ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# Modell für den KI-Assistenten (Default: claude-opus-4-8)
# ANTHROPIC_MODEL=claude-opus-4-8
# Tages-Token-Budget pro User für den KI-Assistenten (0/leer = unbegrenzt)
# CHAT_DAILY_TOKEN_LIMIT=200000

# ---------- E-Mail (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@orynthia.local
# Ohne SMTP: Passwort-Reset-Link inkl. Token ins Backend-Log schreiben?
# Nur für Einzel-Setups ohne Log-Aggregation aktivieren – Logs dürfen
# normalerweise keine Secrets enthalten.
MAIL_FALLBACK_LOG=false

