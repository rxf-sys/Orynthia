# ===========================================
# Orynthia App - Environment Configuration
# ===========================================
# Kopiere diese Datei zu .env und passe die Werte an

# ---------- Allgemein ----------
NODE_ENV=development
APP_PORT=3000
FRONTEND_URL=http://localhost:5173

# ---------- Datenbank ----------
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=orynthia
POSTGRES_PASSWORD=CHANGE_ME_secure_password_123
POSTGRES_DB=orynthia
DATABASE_URL=postgresql://orynthia:CHANGE_ME_secure_password_123@postgres:5432/orynthia?schema=public

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_redis_password_456

# ---------- JWT / Auth ----------
JWT_SECRET=CHANGE_ME_jwt_secret_min_32_chars_long_random_string
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_ME_refresh_secret_min_32_chars_long
JWT_REFRESH_EXPIRES_IN=7d

# ---------- Verschlüsselung ----------
ENCRYPTION_KEY=CHANGE_ME_exactly_32_characters!!

# ---------- Banking API (Enable Banking / Open Banking PSD2) ----------
# Kostenlos registrieren: https://enablebanking.com/sign-in/
# App erstellen unter: https://enablebanking.com (Control Panel -> API Applications)
# Private Key wird beim App-Erstellen generiert (RSA, PEM-Format)
# Im .env den Key einzeilig mit \n als Zeilenumbruch speichern
ENABLE_BANKING_APP_ID=your_application_id
ENABLE_BANKING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----"

# ---------- Optionale KI-Integration ----------
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ---------- E-Mail (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@orynthia.local

# ---------- Sentry (optional) ----------
SENTRY_DSN=
